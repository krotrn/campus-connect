{
  "name": "connect-campus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "prisma generate",
    "format": "prettier --write \"./\"",
    "format:check": "prettier --check \"./\"",
    "validate": "pnpm typecheck && pnpm lint:fix && pnpm format",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "docker:db:migrate": "docker compose exec app-dev pnpm prisma migrate dev",
    "docker:db:deploy": "docker compose exec app-dev pnpm prisma migrate deploy",
    "docker:dev:build": "docker compose build app-dev nginx-dev worker-dev migrator-dev",
    "docker:dev:up": "docker compose --profile dev up",
    "docker:dev:up-nginx": "docker compose --profile dev up nginx-dev",
    "docker:dev:down": "docker compose --profile dev down",
    "docker:dev:logs": "docker compose --profile dev logs -f",
    "docker:dev:logs-app": "docker compose logs -f app-dev",
    "docker:dev:logs-nginx": "docker compose logs -f nginx-dev",
    "docker:prod:build": "docker compose build app-prod nginx-prod worker-prod migrator-prod",
    "docker:prod:up": "docker compose --profile prod up",
    "docker:prod:up-nginx": "docker compose --profile prod up nginx-prod",
    "docker:prod:down": "docker compose --profile prod down",
    "docker:prod:logs": "docker compose --profile prod logs -f",
    "docker:prod:logs-app": "docker compose logs -f app-prod",
    "docker:prod:logs-worker": "docker compose logs -f worker-prod",
    "docker:prod:logs-nginx": "docker compose logs -f nginx-prod",
    "docker:db:logs": "docker compose logs -f db",
    "docker:db:psql": "docker exec -it campus_connect_db psql -U connect -d campus_connect",
    "redis:cli": "docker exec -it campus_connect_redis redis-cli",
    "redis:info": "docker exec campus_connect_redis redis-cli info",
    "redis:memory": "docker exec campus_connect_redis redis-cli info memory",
    "redis:clients": "docker exec campus_connect_redis redis-cli info clients",
    "redis:stats": "docker exec campus_connect_redis redis-cli info stats",
    "redis:keyspace": "docker exec campus_connect_redis redis-cli info keyspace",
    "redis:pubsub:channels": "docker exec campus_connect_redis redis-cli pubsub channels",
    "redis:pubsub:clients": "docker exec campus_connect_redis redis-cli info clients | grep pubsub_clients",
    "redis:pubsub:numsub": "docker exec campus_connect_redis redis-cli pubsub numsub",
    "redis:client:list": "docker exec campus_connect_redis redis-cli client list",
    "redis:bigkeys": "docker exec campus_connect_redis redis-cli --bigkeys",
    "redis:dbsize": "docker exec campus_connect_redis redis-cli dbsize",
    "redis:flushall": "docker exec campus_connect_redis redis-cli flushall",
    "redis:logs": "docker compose logs -f redis",
    "docker:prune": "docker system prune -af --volumes",
    "docker:images": "docker images",
    "docker:ps": "docker ps -a",
    "docker:cleanup:orphaned-files": "docker compose exec app-dev pnpm tsx workers/scripts/cleanup-orphaned-files.ts",
    "docker:cleanup:orphaned-files:dry": "docker compose exec app-dev pnpm tsx workers/scripts/cleanup-orphaned-files.ts --dry-run",
    "docker:cleanup:orphaned-files:prod": "docker compose exec worker-prod npx tsx workers/scripts/cleanup-orphaned-files.ts",
    "cleanup:orphaned-files": "tsx workers/scripts/cleanup-orphaned-files.ts",
    "cleanup:orphaned-files:dry": "tsx workers/scripts/cleanup-orphaned-files.ts --dry-run",
    "build:worker": "tsc -p tsconfig.worker.json && cp -r workers/generated dist/workers"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/query-async-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/react-query-persist-client": "^5.100.14",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@use-gesture/react": "^10.3.1",
    "autoprefixer": "^10.5.0",
    "axios": "^1.16.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-auth": "^1.6.12",
    "bullmq": "^5.77.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.7",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "input-otp": "^1.4.2",
    "ioredis": "^5.11.0",
    "isomorphic-dompurify": "^3.15.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "postcss": "^8.5.15",
    "prom-client": "^15.1.3",
    "radix-ui": "latest",
    "react": "19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.6",
    "react-dropzone": "^15.0.0",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.76.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "baseline-browser-mapping": "^2.10.33",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "ignore-loader": "^0.1.2",
    "lint-staged": "^17.0.6",
    "lodash": "^4.18.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
